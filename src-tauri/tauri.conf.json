{
  "build": {
    "distDir": "../dist",
    "devPath": "../dist"
  },
  "package": {
    "productName": "Retrax-Launcher",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.retrax.launcher",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "window": {
      "fullscreen": false,
      "resizable": true,
      "title": "Retrax-Launcher",
      "width": 800,
      "height": 600
    }
  }
}
