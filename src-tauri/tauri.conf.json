{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Retrac",
  "version": "2.1.2",
  "identifier": "launcher.retrac.site",
  "build": {
    "beforeDevCommand": "yarn run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Retrac",
        "width": 936,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
 "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}